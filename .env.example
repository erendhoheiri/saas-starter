# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/starter
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5433/starter_test

# Auth
AUTH_SECRET=dev-secret-change-me

# URLs
APP_URL=http://localhost:5173
API_URL=http://localhost:3000

# Providers
EMAIL_PROVIDER=console
STORAGE_PROVIDER=local

# Email (Resend) — required when EMAIL_PROVIDER=resend
# RESEND_API_KEY=

# Storage (S3) — required when STORAGE_PROVIDER=s3
# S3_REGION=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=

# OAuth — Google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# OAuth — GitHub
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Observability
# SENTRY_DSN=
