{
  "extends": "@starter/config/tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "outDir": "./node_modules/.tmp/tsc-out",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
