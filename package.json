{
  "name": "saas-starter",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.6",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@starter/db",
    "db:migrate": "turbo run db:migrate --filter=@starter/db",
    "db:seed": "turbo run db:seed --filter=@starter/db",
    "db:studio": "turbo run db:studio --filter=@starter/db"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "turbo": "2.9.18"
  }
}
